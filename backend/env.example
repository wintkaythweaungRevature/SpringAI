# Copy to backend.env on EC2 (or set in your deployment)
# See docs/FACEBOOK_API_SETUP.md for full setup

# Backend base URL (for OAuth callback - must match api.wintaibot.com)
APP_API_BASE_URL=https://api.wintaibot.com

# SPA origin after OAuth redirect (match the site users open: www vs non-www)
# APP_FRONTEND_URL=https://www.wintaibot.com

# Database
DB_URL=jdbc:postgresql://your-rds-host:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=your_password

# JWT (use same secret everywhere that validates tokens)
JWT_SECRET=your-32-char-secret-key-for-jwt-signing
# Optional: expiration in ms (default 7 days). 86400000=24h
# JWT_EXPIRATION_MS=604800000

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Facebook & Instagram (Meta Graph API)
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_ACCESS_TOKEN=your_long_lived_page_token
FACEBOOK_VERIFY_TOKEN=your_verify_token_for_webhooks
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_id

# LinkedIn — see docs/LINKEDIN_OAUTH_SETUP.md (redirect: .../api/social/callback/linkedin)
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
# Optional: LINKEDIN_SCOPE=openid profile email w_member_social
